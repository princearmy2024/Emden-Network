{
    "name": "emden-network",
    "version": "4.58.7",
    "description": "Emden Network - Control Center",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:all": "electron-builder --win --mac"
    },
    "dependencies": {
        "electron-updater": "^6.1.8",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.emdennetwork.dashboard",
        "productName": "Emden Network",
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.ico",
            "requestedExecutionLevel": "requireAdministrator"
        },
        "mac": {
            "target": [
                "dmg"
            ],
            "icon": "assets/logoEN.png",
            "category": "public.app-category.utilities"
        },
        "dmg": {
            "title": "Emden Network",
            "contents": [
                { "x": 130, "y": 220 },
                { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
            ]
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowToChangeInstallationDirectory": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Emden Network"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "princearmy2024",
                "repo": "Emden-Network"
            }
        ]
    },
    "author": "Emden Network",
    "license": "MIT"
}
